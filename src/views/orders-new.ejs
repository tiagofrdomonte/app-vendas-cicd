<%- include('partials/header') %>

<h2 class="mb-3">Nova Ordem de Venda</h2>

<% if (errors && errors.length) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errors.forEach((error) => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<%
  const selectedCustomer = customers.find((c) => String(c.id) === String(data?.customer_id));
  const selectedCustomerName = selectedCustomer ? selectedCustomer.name : '';
%>

<form
  id="orderForm"
  action="/orders"
  method="post"
  class="card p-3"
  data-customers="<%- encodeURIComponent(JSON.stringify(customers)) %>"
  data-products="<%- encodeURIComponent(JSON.stringify(products)) %>"
  data-existing-items="<%- encodeURIComponent(JSON.stringify(Array.isArray(data?.items) ? data.items : [])) %>"
>
  <div class="mb-3 position-relative">
    <label class="form-label" for="customerSearch">Cliente</label>
    <input
      id="customerSearch"
      class="form-control"
      type="text"
      autocomplete="off"
      placeholder="Digite o nome do cliente..."
      value="<%= selectedCustomerName %>"
      required
    />
    <input id="customerId" type="hidden" name="customer_id" value="<%= data?.customer_id || '' %>" />
    <div id="customerResults" class="list-group position-absolute w-100 shadow-sm d-none" style="z-index: 20;"></div>
    <div class="form-text">Digite para filtrar clientes e clique no cliente correto.</div>
  </div>

  <div class="mb-3">
    <label class="form-label">Observações</label>
    <textarea class="form-control" name="notes" rows="2"><%= data?.notes || '' %></textarea>
  </div>

  <h5>Itens</h5>
  <div id="itemsContainer" class="d-flex flex-column gap-2 mb-3"></div>

  <div class="d-flex gap-2 mb-3">
    <button class="btn btn-outline-secondary" type="button" id="addItemBtn">Adicionar item</button>
  </div>

  <button class="btn btn-dark" type="submit">Criar ordem</button>
</form>

<script src="/orders-new.js"></script>

<%- include('partials/footer') %>
