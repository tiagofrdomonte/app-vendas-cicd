<%- include('partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <h2 class="mb-0">Ordens de Venda</h2>
  <a class="btn btn-dark" href="/orders/new">Nova ordem</a>
</div>

<div class="card p-3">
  <div class="table-responsive">
    <table class="table table-striped mb-0">
      <thead>
        <tr>
          <th>ID</th>
          <th>Cliente</th>
          <th>Total</th>
          <th>Data</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach((o) => { %>
          <tr>
            <td><%= o.id %></td>
            <td><%= o.customer_name %></td>
            <td>R$ <%= Number(o.total_amount).toFixed(2) %></td>
            <td><%= new Date(o.created_at).toLocaleString('pt-BR') %></td>
            <td><a class="btn btn-sm btn-outline-primary" href="/orders/<%= o.id %>">Ver</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<%- include('partials/footer') %>
