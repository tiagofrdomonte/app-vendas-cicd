<%- include('partials/header') %>

<h2 class="mb-3">Novo Cliente</h2>

<% if (errors && errors.length) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errors.forEach((error) => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<form action="/customers" method="post" class="card p-3">
  <div class="mb-3">
    <label class="form-label">Nome</label>
    <input class="form-control" name="name" required value="<%= data?.name || '' %>" />
  </div>
  <div class="mb-3">
    <label class="form-label">Email</label>
    <input class="form-control" type="email" name="email" required value="<%= data?.email || '' %>" />
  </div>
  <div class="mb-3">
    <label class="form-label">Telefone</label>
    <input class="form-control" name="phone" value="<%= data?.phone || '' %>" />
  </div>
  <button class="btn btn-primary" type="submit">Salvar</button>
</form>

<%- include('partials/footer') %>
