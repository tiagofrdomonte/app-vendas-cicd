<%- include('partials/header') %>

<h2 class="mb-3">Novo Produto</h2>

<% if (errors && errors.length) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errors.forEach((error) => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<form action="/products" method="post" class="card p-3">
  <div class="mb-3">
    <label class="form-label">SKU</label>
    <input class="form-control" name="sku" required value="<%= data?.sku || '' %>" />
  </div>
  <div class="mb-3">
    <label class="form-label">Nome</label>
    <input class="form-control" name="name" required value="<%= data?.name || '' %>" />
  </div>
  <div class="mb-3">
    <label class="form-label">Preço unitário</label>
    <input class="form-control" type="number" step="0.01" min="0.01" name="unit_price" required value="<%= data?.unit_price || '' %>" />
  </div>
  <button class="btn btn-primary" type="submit">Salvar</button>
</form>

<%- include('partials/footer') %>
